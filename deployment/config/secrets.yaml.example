# Secrets Configuration Example
# THIS FILE MUST BE 600 (root:root) IN PRODUCTION
# Copy to /etc/pi-panel/secrets.yaml and /etc/pi-agent/secrets.yaml

# JWT Secret (Panel only)
jwt_secret: "CHANGE_ME_TO_RANDOM_64_CHAR_STRING"
# Generate with: openssl rand -base64 64

# Panel ↔ Agent HMAC Secret (both panel and agent)
hmac_secret: "CHANGE_ME_TO_RANDOM_128_CHAR_HEX"
# Generate with: openssl rand -hex 64

# Database Encryption Key (if using encrypted DB - future)
# db_encryption_key: "CHANGE_ME"

# First-Run Token (optional, for headless setup)
# first_run_token: "CHANGE_ME"
# If set, /api/auth/first-run/create-owner requires this token

---
# SECURITY NOTES:
# 
# 1. Generate unique secrets for each deployment:
#    - Never use example values
#    - Never commit secrets to git
#    - Never share secrets between environments
#
# 2. File permissions:
#    sudo chown root:root /etc/pi-panel/secrets.yaml
#    sudo chmod 600 /etc/pi-panel/secrets.yaml
#    sudo chown root:root /etc/pi-agent/secrets.yaml
#    sudo chmod 600 /etc/pi-agent/secrets.yaml
#
# 3. Rotation schedule:
#    - JWT secret: Every 90 days
#    - HMAC secret: Every 180 days
#    - After any suspected compromise: Immediately
#
# 4. Backup:
#    - Store encrypted backups in secure location
#    - Use different encryption key than DB
#    - Test restore procedure quarterly
